# 安装内核 可选：mihomo、clash
export KERNEL_TYPE="mihomo"

# 可选订阅（首次安装可留空）
export CLASH_SUBSCRIPTION_URL=""

# 控制器密钥（默认留空）
export CLASH_CONTROLLER_SECRET=""

# 端口
export MIXED_PORT="7890"
export EXTERNAL_CONTROLLER="0.0.0.0:9090"
export CLASH_DNS_PORT="1053"

# 订阅更新策略
export CLASH_AUTO_UPDATE_SUBSCRIPTIONS="true"

# 版本
export MIHOMO_VERSION="v1.19.23"
export CLASH_VERSION="v1.18.0"
export YQ_VERSION="v4.52.4"
export SUBCONVERTER_VERSION="v0.9.0"

# 内置运行依赖（resources/bin），设为 false 可强制跳过内置文件并联网下载
export CLASH_BUNDLED_ASSET_ENABLED="true"
